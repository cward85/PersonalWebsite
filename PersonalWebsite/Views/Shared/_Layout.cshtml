<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="@ViewBag.MetaDescription" />
    <meta name="keywords" content="@ViewBag.MetaKeywords" />
    <meta http-equiv='content-language' content='en-us'>
    <link rel="icon" href="/favicon.ico">
    <title>@ViewBag.Title - Camilo Ward</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

<script type="text/javascript">
        $(document).ready(function () {
            if (localStorage.getItem("colorId") !== null) {
                changeColor(localStorage.getItem("colorId"));
            }
            else {
                localStorage.setItem("colorId", "4");
            }
        });

        function attemptLogin(userNameTB, passwordTB, loginError) {

            const url = '@Url.Action("Login", "Login")';
            var userName = $(userNameTB).val();
            var password = $(passwordTB).val();

            fetch(url, {
                method: "POST",
                headers: { 'Content-Type': 'application/json; charset=utf-8' },
                body: JSON.stringify({ userName: userName, password: password })
            })
            .then(response => {
                return response.json()
                    .then(data => {
                        if (data.message != "Success") {
                            $(loginError).show();
                            $(loginError).text(data.message);
                        }
                        else {
                            location.reload();
                        }
                    });
            });
    }

    function doLogout() {
        const url = '@Url.Action("Logout", "Login")';

        fetch(url, {
            method: "POST",
            headers: { 'Content-Type': 'application/json; charset=utf-8' }
        })
        .then(response => {
            if (!response.ok) {
                $('#loginError').text(response.message);
            }
            else {
                location.reload();
            }
        })
    }

        function changeColor(id) {
            if (id == 1) {
                $(':root').get(0).style.setProperty('--primary-color', "#6A7B76");
                $(':root').get(0).style.setProperty('--secondary-color', "#3A4E48");
                $(':root').get(0).style.setProperty('--primary-accent-color', "#8B9D83");
                $(':root').get(0).style.setProperty('--secondary-accent-color', "#BEB0A7");
                $(':root').get(0).style.setProperty('--tertiary-accent-color', "#C2948A");
            }
            else if (id == 4) {
                $(':root').get(0).style.setProperty('--primary-color', "#404040");
                $(':root').get(0).style.setProperty('--secondary-color', "#585858");
                $(':root').get(0).style.setProperty('--primary-accent-color', "#FFFFFF");
                $(':root').get(0).style.setProperty('--secondary-accent-color', "#9B9B9B");
                $(':root').get(0).style.setProperty('--tertiary-accent-color', "#D3D3D3");
            }
            else if (id == 5) {
                $(':root').get(0).style.setProperty('--primary-color', "#03256C");
                $(':root').get(0).style.setProperty('--secondary-color', "#2541B2");
                $(':root').get(0).style.setProperty('--primary-accent-color', "#FFFFFF");
                $(':root').get(0).style.setProperty('--secondary-accent-color', "#1768AC");
                $(':root').get(0).style.setProperty('--tertiary-accent-color', "#06BEE1");
            }
            else if (id == 6) {
                $(':root').get(0).style.setProperty('--primary-color', "#1B1B3A");
                $(':root').get(0).style.setProperty('--secondary-color', "#9197AE");
                $(':root').get(0).style.setProperty('--primary-accent-color', "#EFF6E0");
                $(':root').get(0).style.setProperty('--secondary-accent-color', "#4A442D");
                $(':root').get(0).style.setProperty('--tertiary-accent-color', "#386150");
            }

            localStorage.setItem("colorId", String(id));
        }
</script>
</head>


<body>
    
    <div class="container">
        <div class="row">
            <div class="row">
                <h1 class="title">Camilo Ward</h1>
                <h3 class="title">Freelance - Web Development - Website Management</h3>
            </div>
            <div class="row" style="padding-bottom:.8em">                
                <div class="topNav border p-1">
                    <div class="dropdown dropup float-start">
                        @if (Session["UserId"] == null || (int)Session["UserId"] == 0)
                        {
                            <button class="btn btn-primary bi bi-gear loginButton" id="loginDropdownButton" type="button" data-coreui-toggle="dropdown" data-coreui-auto-close="outside" aria-expanded="false">
                                <i class="nav-icon cil-options ms-auto d-sidebar-narrow-none"></i>
                            </button>
                            <div class="container">
                                <div class="dropdown-menu p-2 w-100">
                                    <div class="mb-3">
                                        @Html.Label("User Name", new { @class = "form-label required" })
                                        @Html.TextBox("userName", "", new { @class = "form-control" })
                                    </div>
                                    <div class="mb-3">
                                        @Html.Label("Password", new { @class = "form-label required" })
                                        @Html.Password("password", "", new { @class = "form-control" })
                                        <span id="loginError" class="text-danger"></span>
                                    </div>
                                    <div style="padding-top:4px">
                                        <button type="button" class="btn btn-primary float-end login-button" style="padding-top:4px" value="Login" onclick="attemptLogin('#userName', '#password', '#loginError');">                                           
                                            <span id="loginButtonSidebar">Login</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-primary d-flex bi bi-gear loginButton" type="button" data-coreui-auto-close="outside" data-coreui-toggle="dropdown" aria-expanded="false">
                                <div class="small">
                                    <span class="fw-semibold p-2">@((string)Session["Name"])</span>
                                </div>                                
                            </button>
                            <div class="dropdown-menu p-4 w-100">
                                <div class="d-flex gap-2 px-0">
                                    <div class="small text-start">
                                        <div class="fw-semibold">@((string)Session["Name"])</div>                                        
                                    </div>
                                </div>                                
                                <div><hr class="dropdown-divider"></div>
                                <div><a class="dropdown-item d-flex align-items-center gap-2" href="#" onclick="doLogout();"><i class="cil-account-logout"></i>Logout</a></div>
                            </div>
                        }
                    </div>
                    <div class="nav float-end">
                        <div class="nav-item">@Html.ActionLink("About", "", "About", new { area = "" }, new { @class = "nav-link" })</div>
                        <div class="nav-item">@Html.ActionLink("Freelance Opportunities", "", "Freelance", new { area = "" }, new { @class = "nav-link" })</div>
                        <div class="nav-item">@Html.ActionLink("Portfolio", "", "Portfolio", new { area = "" }, new { @class = "nav-link" })</div>
                        <div class="nav-item">@Html.ActionLink("Resume (WIP)", "", "Resume", new { area = "" }, new { @class = "nav-link disabled" })</div>
                        <div class="nav-item">@Html.ActionLink("Blog", "", "Blog", new { area = "" }, new { @class = "nav-link" })</div>
                        <div class="nav-item">
                            <div class="btn-group">
                                <button type="button" class="btn btn-primary dropdown-toggle" data-coreui-toggle="dropdown" aria-expanded="false">
                                    Site Color Theme Picker
                                </button>
                                <div class="dropdown-menu">
                                    <div><hr class="dropdown-divider">Dark Greenish</div>
                                    <div><a class="dropdown-item" style="background-color: #6A7B76" onclick="changeColor(1);" href="#">Primary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #3A4E48" onclick="changeColor(1);" href="#">Secondary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #8B9D83" onclick="changeColor(1);" href="#">Primary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #BEB0A7" onclick="changeColor(1);" href="#">Secondary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #C2948A" onclick="changeColor(1);" href="#">Tertiary Accent Color</a></div>
                                    <div><hr class="dropdown-divider">Various Greys</div>
                                    <div><a class="dropdown-item" style="background-color: #404040" onclick="changeColor(4);" href="#">Primary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #585858" onclick="changeColor(4);" href="#">Secondary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #FFFFFF" onclick="changeColor(4);" href="#">Primary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #9B9B9B" onclick="changeColor(4);" href="#">Secondary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #D3D3D3" onclick="changeColor(4);" href="#">Tertiary Accent Color</a></div>
                                    <div><hr class="dropdown-divider">Blue</div>
                                    <div><a class="dropdown-item" style="background-color: #03256C" onclick="changeColor(5);" href="#">Primary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #2541B2" onclick="changeColor(5);" href="#">Secondary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #FFFFFF" onclick="changeColor(5);" href="#">Primary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #1768AC" onclick="changeColor(5);" href="#">Secondary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #06BEE1" onclick="changeColor(5);" href="#">Tertiary Accent Color</a></div>
                                    <div><hr class="dropdown-divider">Grey/green</div>
                                    <div><a class="dropdown-item" style="background-color: #1B1B3A" onclick="changeColor(6);" href="#">Primary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #9197AE" onclick="changeColor(6);" href="#">Secondary Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #EFF6E0" onclick="changeColor(6);" href="#">Primary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #4A442D" onclick="changeColor(6);" href="#">Secondary Accent Color</a></div>
                                    <div><a class="dropdown-item" style="background-color: #386150" onclick="changeColor(6);" href="#">Tertiary Accent Color</a></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="sidebar border col">
                    <ul class="sidebar-nav compact">

                        <li class="nav-title">Links</li>
                        <li class="nav-item">
                            <a class="nav-link" href="https://www.linkedin.com/in/camiloward/" target="_blank">
                                <img src="~/Content/images/LI-In-Bug.png" height="40" alt="Linked In - Camilo Ward" />
                            </a>
                            <a class="nav-link" href="https://github.com/cward85" target="_blank">
                                <img src="~/Content/images/GitHub_Lockup_White.png" height="30" alt="GitHub - Camilo Ward" />
                            </a>
                            <a class="nav-link" href="@Url.Action("ResumeDownload", "About")" download>
                                <img src="~/Content/images/pdf-download.jpg" height="40" alt="Download Current Resume - Camilo Ward" /><span class="accent" style="padding-left:1em">Current Resume</span>
                            </a>
                        </li>
                        <li class="nav-title">Contact</li>
                        <li class="nav-item">
                            <a class="nav-link" href="mailto:me@camiloward.com">
                                <span id="emailContactSidebar" class="accent">me@camiloward.com</span>
                            </a>
                        </li>
                        <li class="nav-title">Location</li>
                        <li class="nav-item">
                            <span class="accent" style="padding-left:1em">Washington, DC</span>
                        </li>
                        <li class="nav-title">Freelance Status</li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("", "Freelance")">
                                <span id="freelanceStatusSidebar" class="accent">Open for Work</span>
                            </a>
                        </li>
                        <li class="nav-title">Technologies</li>
                        <li class="nav-item">
                            <span>Back End</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">C#</span>
                                <span class="chip">SQL</span>
                                <span class="chip">Visual Basic</span>
                                <span class="chip">Java</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>Front End</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">javascript</span>
                                <span class="chip">jQuery</span>
                                <span class="chip">AJAX</span>
                                <span class="chip">CSS</span>
                                <span class="chip">Bootstrap</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>Source Control</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">TFS</span>
                                <span class="chip">Azure Devops</span>
                                <span class="chip">GitHub</span>
                                <span class="chip">TortoiseSVN</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>.NET Frameworks</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">Webforms (Framework 3.5-4.8)</span>
                                <span class="chip">MVC 5</span>
                                <span class="chip">.NET Core (5+)</span>
                                <span class="chip">Windows Forms</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>Data Formats</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">JSON</span>
                                <span class="chip">XML</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>Software</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">SQL Server Management Studio</span>
                                <span class="chip">IIS</span>
                                <span class="chip">Visual Studio 2008-2026</span>
                                <span class="chip">MS Project</span>
                                <span class="chip">GitHub Desktop</span>
                                <span class="chip">Unity</span>
                                <span class="chip">articy draft x</span>
                                <span class="chip">VSCode</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span>Methodologies</span>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="chip">Agile</span>
                                <span class="chip">Scrum</span>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="col" style="padding-right:0em">
                    <div class="container-lg border">
                        @RenderBody()

                        <footer class="mt-auto">
                            <hr />
                            <p>&copy; @DateTime.Now.Year - Camilo Ward</p>
                        </footer>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
